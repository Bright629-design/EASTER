{
  "version": 2,
  "builds": [
    { "src": "api/**/*.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/stats/(.*)", "dest": "/api/stats/[name].js?name=$1" },
    { "src": "/api/visit",  "dest": "/api/visit.js" },
    { "src": "/api/visits", "dest": "/api/visits.js" },
    { "src": "/(.*\\.(mp3|css|js|png|jpg|webp|ico|svg|woff2?))", "dest": "/public/$1" },
    { "src": "/(.*)", "dest": "/public/index.html" }
  ]
}
